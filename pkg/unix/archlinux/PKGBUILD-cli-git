pkgname=minoctl-git
pkgver=0.8.0
pkgrel=1
pkgdesc="minoctl git build"
arch=('x86_64')
url="https://github.com/Delfi-CH/minopanel"
license=('AGPL-3.0-or-later')
depends=('nodejs')
makedepends=('pnpm')

options=(!debug)
provides=('minoctl')
conflicts=('minoctl')

source=("git+https://github.com/Delfi-CH/minopanel.git")
sha256sums=('SKIP')

prepare() {
    cd $srcdir/minopanel
    pnpm install
    pnpm cli:build
}

package() {
    cd $srcdir/minopanel
    mkdir -p "$pkgdir/etc/minopanel.d"
    mkdir -p "$pkgdir/var/lib/minopanel"
    chmod -R 777 "$pkgdir/etc/minopanel.d"
    chmod -R 777 "$pkgdir/var/lib/minopanel"
    install -Dm755 pkg/unix/minoctl -t "$pkgdir/usr/bin/"
    install -Dm755 dist/minoctl.cjs -t "$pkgdir/var/lib/minopanel/bin/"

    # Generate Shell Completion
    node ./dist/minoctl.cjs complete bash > $pkgdir /etc/bash_completion.d/minoctl
    sed -i \
        's|requestComp=".*complete --|requestComp="minoctl complete --|g' \
        $pkgdir/etc/bash_completion.d/minoctl

    node ./dist/minoctl.cjs complete zsh > $pkgdir/usr/share/zsh/site-functions/_minoctl
    sed -i \
        's|requestComp=".*complete --|requestComp="minoctl complete --|g' \
        $pkgdir/usr/share/zsh/site-functions/_minoctl

    node ./dist/minoctl.cjs complete fish > $pkgdir/usr/share/fish/completions/minoctl.fish
    sed -i \
        's|set -l requestComp ".*|set -l requestComp "minoctl complete -- (string join '"'"' '"'"' -- (string escape -- $args[2..-1])) $lastArg"|g' \
        $pkgdir/usr/share/fish/completions/minoctl.fish
}