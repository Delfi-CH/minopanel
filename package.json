{
	"name": "minopanel",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"license": "AGPL-3.0-or-later",
	"scripts": {
		"frontend:dev": "vite dev",
		"frontend:build": "vite build && esbuild src/web/index.ts --bundle --platform=node --format=cjs --outfile=dist/minowebd.cjs",
		"frontend:serve": "tsx src/web/index.ts",
		"frontend:package:deb" : "pnpm frontend:build && cd pkg/unix/dpkg && ./build-web.sh",
		"server:dev": "tsx --watch src/server/index.ts",
		"server:build": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/minopaneld.cjs --external:node-pty --external:node-downloader-helper",
		"server:package:deb" : "pnpm server:build && cd pkg/unix/dpkg && ./build-server.sh",
		"cli:dev": "tsx src/cli/main.ts",
		"cli:build": "esbuild src/cli/main.ts --bundle --platform=node --format=cjs --outfile=dist/minoctl.cjs --external:node-downloader-helper",
		"cli:package:deb" : "pnpm cli:build && cd pkg/unix/dpkg && ./build-cli.sh",
		"installer:dev": "tsx src/install/main.ts",
		"installer:build": "esbuild src/install/main.ts --bundle --platform=node --format=cjs --outfile=dist/minopanel-installer.cjs --external:node-downloader-helper",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/archiver": "^8.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^24",
		"@types/ws": "^8.18.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.22.4",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"@delfi-ch/ini.js": "^0.1.1",
		"@delfi-ch/linux-os-info-esmodule": "^2.0.3",
		"@fontsource/roboto": "^5.2.10",
		"@logdna/tail-file": "^4.0.2",
		"@sveltestrap/sveltestrap": "^7.1.0",
		"@xhmikosr/decompress": "^11.1.3",
		"@xhmikosr/decompress-targz": "^9.0.1",
		"@xhmikosr/decompress-unzip": "^8.1.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"ansi-colors": "^4.1.3",
		"archiver": "^8.0.0",
		"axios": "^1.17.0",
		"bootstrap-icons": "^1.13.1",
		"bootswatch": "^5.3.8",
		"cli-progress": "^3.12.0",
		"commander": "^15.0.0",
		"cors": "^2.8.6",
		"easy-table": "^1.2.0",
		"esbuild": "^0.28.1",
		"express": "^5.2.1",
		"get-port": "^7.2.0",
		"is-node": "^1.1.1",
		"multer": "^2.2.0",
		"node-downloader-helper": "^2.1.11",
		"node-pty": "^1.1.0",
		"ws": "^8.21.0"
	}
}
